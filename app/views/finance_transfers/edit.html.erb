<%= turbo_frame_tag "content", data: {turbo_action: :advance} do %>
  <div class="container p-4 my-4 is-max-tablet">
    <div class="is-flex is-justify-content-space-between">
      <%= tag.h1 "Edit #{@transfer.category.to_s.singularize}", class: "title" %>
      <%= button_to "Delete", @transfer, method: :delete, class: "button" %>
    </div>
    <%= render "form" %>
  </div>
<% end %>

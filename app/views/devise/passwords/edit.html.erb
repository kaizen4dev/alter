<div class="container p-6 is-max-tablet">
  <h2 class="title">Change your password</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div class="field">
      <p><%= f.label :password, "New password", class: "label is-medium" %></p>
      <% if @minimum_password_length %>
        <p><em>(<%= @minimum_password_length %> characters minimum)</em></p>
      <% end %>
      <p><%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "input is-medium" %></p>
    </div>

    <div class="field">
      <p><%= f.label :password_confirmation, "Confirm new password", class: "label is-medium" %></p>
      <p><%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input is-medium" %></p>
    </div>

    <div class="actions">
      <%= f.submit "Change my password", class: "button mb-2 is-primary" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>

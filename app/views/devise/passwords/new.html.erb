<div class="container p-6 is-max-tablet">
  <h2 class="title">Forgot your password?</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <p><%= f.label :email, class: "label is-medium" %></p>
      <p><%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input is-medium" %></p>
    </div>

    <div class="actions">
      <%= f.submit "Send me password reset instructions", class: "button mb-2 is-primary" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
